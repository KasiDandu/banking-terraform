# Real environment -- points at the actual banking-data test stack.
export AWS_REGION=us-east-1
export BACKEND_BUCKET=kvrd-artifacts
export PREFIX_KEY=banking-terraform/test/state.tfstate
export LOCK_TABLE=banking-data-test-tfstate-lock

export TF_VAR_environment=test
export TF_VAR_aws_region=us-east-1
export TF_VAR_artifact_bucket=kvrd-artifacts

# Pinned snapshot of the last known-good build (banking-artifacts'
# build-release.yaml build job output), used as a fallback default only --
# the := form leaves an already-exported value alone. CI resolves these
# dynamically (see main.yaml's "Resolve latest build artifact keys" step)
# and exports them into $GITHUB_ENV *before* this file gets sourced, so the
# fallback here only ever kicks in for local/manual Terragrunt runs.
#
# lambda_s3_keys/glue_script_s3_keys are map(string) variables (keyed by the
# logical name in lambda.json/glue.json) -- Terraform parses a TF_VAR_* env
# var's JSON content directly into a map/object-typed variable.
export TF_VAR_lambda_s3_keys="${TF_VAR_lambda_s3_keys:-{\"event_handler\":\"lambda/sha256/e5ac6bf677df20ad00996a99e40dd1dcd96d25fd73abe65d1a4ffbed813e44d2/lambda.zip\"}}"
export TF_VAR_glue_script_s3_keys="${TF_VAR_glue_script_s3_keys:-{\"etl\":\"glue/sha256/940a86350107df97707ec9086ec86313c7e4c55dea0ae37b6d400f0da356c2b4/glue_script.py\"}}"
export TF_VAR_glue_common_s3_key="${TF_VAR_glue_common_s3_key:-glue/sha256/0a968279d3792750c2a59f610399d8fb47354485769f97f7a697aeea9b1b961a/glue-common.zip}"
