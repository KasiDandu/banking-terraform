# Real environment -- points at the actual banking-data test stack.
export AWS_REGION=us-east-1
export BACKEND_BUCKET=kvrd-artifacts
# Prefix, not a full key -- each of the three sibling units (buckets/iam/
# banking-data) appends its own "<unit>/terraform.tfstate" under this.
export PREFIX_KEY=banking-terraform/test
export LOCK_TABLE=banking-data-test-tfstate-lock

export TF_VAR_environment=test
export TF_VAR_aws_region=us-east-1
export TF_VAR_artifact_bucket=kvrd-artifacts

# Artifact version pins (lambda_s3_keys/glue_script_s3_keys/glue_common_s3_key)
# are no longer exported as TF_VAR_* here -- they live in
# terraform/live/banking-data.tfvars, passed via the banking-data unit's
# extra_arguments "-var-file". A -var-file always outranks TF_VAR_* in
# Terraform's precedence order, so exporting them here would be dead weight
# at best and silently ignored at worst. CI overwrites that .tfvars file with
# the latest build's keys before planning; local/manual runs use whatever is
# committed there.
