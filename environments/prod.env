# --- PLACEHOLDER: no prod AWS account exists yet ---
# Every value below deliberately points at something that doesn't exist, so
# running Terragrunt against this env fails loudly (AssumeRole/NoSuchBucket)
# instead of silently landing in the test account. Fill these in for real
# once a prod account is provisioned (bootstrap its backend via
# terraform/backend/ first, see that root's file header).
#
# If/when there's more than one prod account, follow this repo's naming
# convention and add one file per account, e.g. 123456789012_prod.env,
# rather than overloading this single prod.env.

export AWS_REGION=us-east-1
export BACKEND_BUCKET=REPLACE_ME-banking-data-prod-tfstate
# Prefix, not a full key -- each of the three sibling units (buckets/iam/
# banking-data) appends its own "<unit>/terraform.tfstate" under this.
export PREFIX_KEY=banking-terraform/prod
export LOCK_TABLE=banking-data-prod-tfstate-lock

export TF_VAR_environment=prod
export TF_VAR_aws_region=us-east-1
export TF_VAR_assume_role_arn="arn:aws:iam::000000000000:role/banking-terraform-deploy"
export TF_VAR_artifact_bucket=REPLACE_ME-banking-data-prod-artifacts

export TF_VAR_lambda_s3_keys='{"event_handler":"REPLACE_ME"}'
export TF_VAR_glue_script_s3_keys='{"etl":"REPLACE_ME"}'
export TF_VAR_glue_common_s3_key=REPLACE_ME
